{
  "name": "workclaw",
  "private": true,
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "brand:apply": "node scripts/apply-brand.mjs",
    "app": "node scripts/start-runtime-dev.mjs",
    "runtime": "node scripts/start-runtime-dev.mjs",
    "build:app": "node scripts/build-runtime.mjs",
    "build:runtime": "node scripts/build-runtime.mjs",
    "doctor:windows": "node scripts/doctor-windows.mjs",
    "report:frontend-large-files": "node scripts/report-frontend-large-files.mjs",
    "report:rust-large-files": "node scripts/report-rust-large-files.mjs",
    "test:e2e:runtime": "node scripts/run-runtime-e2e.mjs",
    "release:check-version": "node scripts/check-release-version.mjs",
    "test:release": "node --test scripts/check-release-version.test.mjs",
    "test:installer": "node --test scripts/check-installer-branding.test.mjs scripts/check-runtime-binary-selection.test.mjs",
    "test:apply-brand": "node --test scripts/apply-brand.test.mjs",
    "test:local-build-script": "node --test scripts/check-local-build-script.test.mjs",
    "test:release-docs": "node --test scripts/check-release-docs.test.mjs",
    "test:openclaw-vendor-lane": "node --test scripts/check-openclaw-vendor-lane.test.mjs",
    "eval:agent-real": "node scripts/run-agent-evals.mjs",
    "test:rust-fast": "node scripts/test-rust-fast.mjs",
    "cargo:isolated": "node scripts/run-cargo-isolated.mjs",
    "cache:build:check": "node scripts/check-build-cache.mjs",
    "cache:build:clean": "node scripts/check-build-cache.mjs --mode=clean",
    "test:builtin-skills": "cargo test --manifest-path packages/builtin-skill-checks/Cargo.toml -- --nocapture",
    "sync:openclaw-core": "node scripts/sync-openclaw-core.mjs",
    "sync:openclaw-im-core": "node scripts/sync-openclaw-im-core.mjs",
    "sync:codex-skills": "node scripts/sync-codex-skills.mjs",
    "test:sidecar": "pnpm --dir apps/runtime/sidecar test",
    "test:browser-automation": "pnpm --dir apps/runtime/sidecar test && cd apps/runtime/src-tauri && cargo test --test test_browser_tools -- --nocapture"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
